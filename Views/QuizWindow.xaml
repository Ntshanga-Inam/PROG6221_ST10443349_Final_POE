<Window x:Class="CybersecurityChatbot_Part2_WPF.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🎮 Cybersecurity Quiz Game"
        Height="600" 
        Width="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#ECF0F1">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="WarningColor" Color="#F39C12"/>

        <Style x:Key="QuizButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A6DA0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OptionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Margin" Value="5,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EBF5FB"/>
                                <Setter Property="BorderBrush" Value="{StaticResource SecondaryColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Padding="20" CornerRadius="10,10,0,0">
            <StackPanel>
                <TextBlock Text="🎮 CYBERSECURITY QUIZ CHALLENGE" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="ScoreTextBlock" 
                           Text="Score: 0 / 0" 
                           FontSize="14" 
                           Foreground="#BDC3C7" 
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
                <ProgressBar x:Name="ProgressBar" 
                             Height="8" 
                             Margin="0,10,0,0" 
                             Foreground="{StaticResource SuccessColor}"
                             Background="#555"/>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel x:Name="MainContentPanel">

                <!-- Start Screen -->
                <StackPanel x:Name="StartScreen" Visibility="Visible">
                    <Border Background="White" CornerRadius="15" Padding="30" Margin="0,20">
                        <StackPanel>
                            <TextBlock Text="🎯 Ready to Test Your Cybersecurity Knowledge?" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource PrimaryColor}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>

                            <TextBlock Text="Challenge yourself with 11 cybersecurity questions covering passwords, phishing, safe browsing, and more!"
                                       FontSize="13" 
                                       Foreground="#7F8C8D"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,15,0,0"/>

                            <Border Background="#E8F8F5" CornerRadius="10" Padding="15" Margin="0,20">
                                <TextBlock Text="📌 Tips:" 
                                           FontWeight="Bold"
                                           Foreground="{StaticResource SuccessColor}">
                                    <LineBreak/>
                                    <Run Text="• Read each question carefully" FontWeight="Normal"/>
                                    <LineBreak/>
                                    <Run Text="• You'll get immediate feedback" FontWeight="Normal"/>
                                    <LineBreak/>
                                    <Run Text="• Final score with personalized feedback" FontWeight="Normal"/>
                                </TextBlock>
                            </Border>

                            <Button Content="🚀 START QUIZ" 
                                    Style="{StaticResource QuizButtonStyle}"
                                    FontSize="18"
                                    Padding="30,15"
                                    Click="StartQuiz_Click"
                                    Margin="0,20"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Question Screen -->
                <StackPanel x:Name="QuestionScreen" Visibility="Collapsed">
                    <Border Background="White" CornerRadius="15" Padding="30">
                        <StackPanel>
                            <TextBlock x:Name="QuestionNumberText" 
                                       Text="Question 1 of 11" 
                                       FontSize="12" 
                                       Foreground="{StaticResource SecondaryColor}"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="QuestionTextBlock" 
                                       FontSize="18" 
                                       FontWeight="Bold" 
                                       Foreground="{StaticResource PrimaryColor}"
                                       TextWrapping="Wrap"
                                       Margin="0,15,0,20"/>

                            <ItemsControl x:Name="OptionsListControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding}" 
                                                Style="{StaticResource OptionButtonStyle}"
                                                Click="OptionButton_Click"
                                                Tag="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}, Path=ItemsControl.Items.IndexOf}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Feedback Screen -->
                <StackPanel x:Name="FeedbackScreen" Visibility="Collapsed" Margin="0,10">
                    <Border x:Name="FeedbackBorder" CornerRadius="15" Padding="20">
                        <StackPanel>
                            <TextBlock x:Name="FeedbackIcon" FontSize="30" TextAlignment="Center"/>
                            <TextBlock x:Name="FeedbackTextBlock" 
                                       FontSize="14" 
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,10"/>
                            <TextBlock x:Name="CorrectAnswerBlock" 
                                       FontSize="13" 
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SuccessColor}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,10"/>
                            <TextBlock x:Name="ExplanationBlock" 
                                       FontSize="13" 
                                       Foreground="#7F8C8D"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,10"/>
                            <Button x:Name="NextButton" 
                                    Content="➡️ NEXT QUESTION" 
                                    Style="{StaticResource QuizButtonStyle}"
                                    Click="NextQuestion_Click"
                                    Margin="0,15"
                                    Width="200"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Results Screen -->
                <StackPanel x:Name="ResultsScreen" Visibility="Collapsed">
                    <Border Background="White" CornerRadius="15" Padding="30">
                        <StackPanel>
                            <TextBlock x:Name="ResultIcon" FontSize="48" TextAlignment="Center"/>
                            <TextBlock x:Name="ResultTitle" 
                                       FontSize="24" 
                                       FontWeight="Bold" 
                                       TextAlignment="Center"
                                       Margin="0,10"/>
                            <TextBlock x:Name="ScoreDisplay" 
                                       FontSize="18" 
                                       TextAlignment="Center"
                                       Margin="0,10"/>
                            <TextBlock x:Name="PercentageDisplay" 
                                       FontSize="14" 
                                       TextAlignment="Center"
                                       Foreground="{StaticResource SecondaryColor}"
                                       Margin="0,5"/>
                            <Border Background="#E8F8F5" CornerRadius="10" Padding="15" Margin="0,20">
                                <TextBlock x:Name="FinalFeedbackBlock" 
                                           FontSize="14" 
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </Border>

                            <WrapPanel HorizontalAlignment="Center" Margin="0,10">
                                <Button Content="🔄 PLAY AGAIN" 
                                        Style="{StaticResource QuizButtonStyle}"
                                        Click="PlayAgain_Click"
                                        Width="150"/>
                                <Button Content="🏠 BACK TO CHAT" 
                                        Style="{StaticResource QuizButtonStyle}"
                                        Click="BackToChat_Click"
                                        Width="150"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8F9F9" Padding="10" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="💡 Tip: Learn from each explanation to improve your cybersecurity knowledge!" 
                       FontSize="11" 
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>