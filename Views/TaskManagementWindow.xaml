<Window x:Class="CybersecurityChatbot_Part2.Views.TaskManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Task Manager - Cybersecurity Tasks"
        Height="550" 
        Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#ECF0F1">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
        <SolidColorBrush x:Key="DangerColor" Color="#E74C3C"/>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A6DA0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style for Complete button (green) -->
        <Style x:Key="CompleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Delete button (red) -->
        <Style x:Key="DeleteButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Style for Close button (gray) -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="#7F8C8D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Background="{StaticResource PrimaryColor}" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="📋 MY CYBERSECURITY TASKS" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Manage your cybersecurity tasks and reminders" 
                           FontSize="11" 
                           Foreground="#BDC3C7"
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Task List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ListBox x:Name="TasksListBox" 
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="13"
                     SelectionMode="Single">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FFFFFF" 
                                CornerRadius="8" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1"
                                Margin="5,5"
                                Padding="10">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding StatusIcon}" FontSize="16" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Title}" 
                                               FontWeight="Bold" 
                                               FontSize="14"
                                               TextDecorations="{Binding CompletedDecorations}"
                                               Foreground="#2C3E50"/>
                                </StackPanel>
                                <TextBlock Text="{Binding Description}" 
                                           TextWrapping="Wrap"
                                           Margin="26,5,0,5"
                                           Foreground="#555"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding DisplayReminder}" 
                                           FontSize="11"
                                           Foreground="#7F8C8D"
                                           Margin="26,0,0,0"/>
                                <StackPanel Orientation="Horizontal" Margin="26,5,0,0">
                                    <TextBlock Text="Created: " 
                                               FontSize="10"
                                               Foreground="#95A5A6"/>
                                    <!-- FIXED: Added quotes around StringFormat -->
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='MMM dd, yyyy'}" 
                                               FontSize="10"
                                               Foreground="#95A5A6"/>
                                    <TextBlock Text=" | Status: " 
                                               FontSize="10"
                                               Foreground="#95A5A6"
                                               Margin="10,0,0,0"/>
                                    <TextBlock Text="{Binding Status}" 
                                               FontSize="10"
                                               Foreground="{Binding StatusColor}"
                                               FontWeight="Bold"/>
                                </StackPanel>
                                <!-- Show completion date if completed -->
                                <StackPanel Orientation="Horizontal" Margin="26,5,0,0" 
                                            Visibility="{Binding ShowCompletionDate}">
                                    <TextBlock Text="Completed: " 
                                               FontSize="10"
                                               Foreground="#27AE60"/>
                                    <TextBlock Text="{Binding CompletedAt, StringFormat='MMM dd, yyyy'}" 
                                               FontSize="10"
                                               Foreground="#27AE60"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>

        <!-- Buttons -->
        <WrapPanel Grid.Row="2" Margin="0,10" HorizontalAlignment="Center">
            <Button x:Name="RefreshBtn" Content="🔄 Refresh" Width="100" 
                    Style="{StaticResource ActionButtonStyle}" Click="RefreshBtn_Click"/>
            <Button x:Name="CompleteBtn" Content="✅ Mark Complete" Width="120" 
                    Style="{StaticResource CompleteButtonStyle}" Click="CompleteBtn_Click"/>
            <Button x:Name="DeleteBtn" Content="🗑️ Delete Task" Width="100" 
                    Style="{StaticResource DeleteButtonStyle}" Click="DeleteBtn_Click"/>
            <Button x:Name="CloseBtn" Content="✖️ Close" Width="80" 
                    Style="{StaticResource CloseButtonStyle}" Click="CloseBtn_Click"/>
        </WrapPanel>
    </Grid>
</Window>