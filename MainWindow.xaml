<Window x:Class="CybersecurityChatbot_Part2_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot - South Africa"
        Height="700" 
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1">

    <Window.Resources>
        <!-- Define colors as resources -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#2C3E50"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="AccentColor" Color="#E74C3C"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#27AE60"/>
        <SolidColorBrush x:Key="BackgroundColor" Color="#ECF0F1"/>
        <SolidColorBrush x:Key="UserMessageColor" Color="#3498DB"/>
        <SolidColorBrush x:Key="BotMessageColor" Color="#FFFFFF"/>

        <!-- Quick Button Style -->
        <Style x:Key="QuickButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="20" 
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A6DA0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send Button Style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2980B9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Voice Button Style -->
        <Style x:Key="VoiceButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SuccessColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Padding="10,5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#229954"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource PrimaryColor}" 
                CornerRadius="10,10,0,0" 
                Padding="15">
            <StackPanel>
                <TextBlock Text="🛡️ CYBERSECURITY AWARENESS BOT" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Protecting South African Citizens Online" 
                           FontSize="12" 
                           Foreground="#BDC3C7" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- ASCII Art -->
        <Border Grid.Row="1" 
                Background="#2C3E50" 
                Margin="0,10,0,10" 
                Padding="10"
                CornerRadius="5">
            <TextBlock x:Name="AsciiArtBlock" 
                       FontFamily="Consolas" 
                       FontSize="10" 
                       Foreground="#3498DB" 
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Chat Messages Area -->
        <Border Grid.Row="2" 
                Background="White" 
                CornerRadius="10" 
                BorderBrush="#BDC3C7" 
                BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer" 
                          VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="ChatHistoryListBox" 
                         Background="Transparent" 
                         BorderThickness="0"
                         FontSize="13">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="10,5,10,5">
                                <TextBlock Text="{Binding Sender}" 
                                           FontWeight="Bold" 
                                           Foreground="{Binding Color}"
                                           FontSize="12"
                                           Margin="5,0,5,0"/>
                                <Border Background="{Binding BackgroundColor}"
                                        CornerRadius="10"
                                        Padding="10"
                                        Margin="5,2,5,5">
                                    <TextBlock Text="{Binding Message}" 
                                               TextWrapping="Wrap"
                                               Foreground="{Binding TextColor}"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- Quick Action Buttons -->
        <WrapPanel Grid.Row="3" 
                   Margin="0,10" 
                   HorizontalAlignment="Center">
            <Button x:Name="PasswordTipBtn" 
                    Content="🔐 Password Tips" 
                    Width="120" 
                    Height="35"
                    Margin="5"
                    Style="{StaticResource QuickButtonStyle}"
                    Click="PasswordTipBtn_Click"/>
            <Button x:Name="PhishingTipBtn" 
                    Content="🎣 Phishing Tips" 
                    Width="120" 
                    Height="35"
                    Margin="5"
                    Style="{StaticResource QuickButtonStyle}"
                    Click="PhishingTipBtn_Click"/>
            <Button x:Name="ScamTipBtn" 
                    Content="⚠️ Scam Alerts" 
                    Width="120" 
                    Height="35"
                    Margin="5"
                    Style="{StaticResource QuickButtonStyle}"
                    Click="ScamTipBtn_Click"/>
            <Button x:Name="PrivacyTipBtn" 
                    Content="🛡️ Privacy Tips" 
                    Width="120" 
                    Height="35"
                    Margin="5"
                    Style="{StaticResource QuickButtonStyle}"
                    Click="PrivacyTipBtn_Click"/>
            <Button x:Name="AnotherTipBtn" 
                    Content="🔄 Another Tip" 
                    Width="120" 
                    Height="35"
                    Margin="5"
                    Style="{StaticResource QuickButtonStyle}"
                    Click="AnotherTipBtn_Click"/>
            <Button x:Name="ClearChatBtn" 
                    Content="🗑️ Clear Chat" 
                    Width="120" 
                    Height="35"
                    Margin="5"
                    Background="#E74C3C"
                    Foreground="White"
                    Style="{StaticResource QuickButtonStyle}"
                    Click="ClearChatBtn_Click"/>
        </WrapPanel>

        <!-- Input Area -->
        <Border Grid.Row="4" 
                Background="White" 
                CornerRadius="10" 
                BorderBrush="#BDC3C7" 
                BorderThickness="1" 
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="InputTextBox" 
                         Grid.Column="0"
                         TextWrapping="Wrap"
                         MinHeight="60"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="14"
                         Padding="10"
                         KeyDown="InputTextBox_KeyDown"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="📤 Send"
                        Width="80"
                        Height="40"
                        Margin="5,0,5,0"
                        Click="SendButton_Click"
                        Style="{StaticResource SendButtonStyle}"/>

                <Button x:Name="VoiceButton"
                        Grid.Column="2"
                        Content="🎤"
                        Width="50"
                        Height="40"
                        ToolTip="Play voice greeting"
                        Click="VoiceButton_Click"
                        Style="{StaticResource VoiceButtonStyle}"/>
            </Grid>
        </Border>
    </Grid>
</Window>